class Solution {
    public List<String> letterCasePermutation(String s) {
        List<String> result = new ArrayList<>();

        dfs(
            s,
            0,
            new StringBuilder(),
            result
        );

        return result;
    }

    private void dfs(
            String s,
            int index,
            StringBuilder current,
            List<String> result) {

        if (index == s.length()) {

            result.add(current.toString());
            return;
        }

        char c = s.charAt(index);

        if (Character.isDigit(c)) {

            current.append(c);

            dfs(
                s,
                index + 1,
                current,
                result
            );

            current.deleteCharAt(
                current.length() - 1
            );
        }
        else {

            current.append(
                Character.toLowerCase(c)
            );

            dfs(
                s,
                index + 1,
                current,
                result
            );

            current.deleteCharAt(
                current.length() - 1
            );

            current.append(
                Character.toUpperCase(c)
            );

            dfs(
                s,
                index + 1,
                current,
                result
            );

            current.deleteCharAt(
                current.length() - 1
            );
        }
    }
}
