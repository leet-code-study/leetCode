class Solution {
    public boolean validTicTacToe(String[] board) {
        int xCount = 0;
        int oCount = 0;

        for (String row : board) {
            for (char c : row.toCharArray()) {

                if (c == 'X') {
                    xCount++;
                } else if (c == 'O') {
                    oCount++;
                }
            }
        }

        // X는 항상 먼저 시작
        if (!(xCount == oCount || xCount == oCount + 1)) {
            return false;
        }

        boolean xWin = isWinner(board, 'X');
        boolean oWin = isWinner(board, 'O');

        // 둘 다 이길 수 없음
        if (xWin && oWin) {
            return false;
        }

        // X가 이겼다면 마지막 수는 X
        if (xWin && xCount != oCount + 1) {
            return false;
        }

        // O가 이겼다면 마지막 수는 O
        if (oWin && xCount != oCount) {
            return false;
        }

        return true;
    }

    private boolean isWinner(String[] board, char player) {

        // 행
        for (int r = 0; r < 3; r++) {
            if (board[r].charAt(0) == player &&
                board[r].charAt(1) == player &&
                board[r].charAt(2) == player) {
                return true;
            }
        }

        // 열
        for (int c = 0; c < 3; c++) {
            if (board[0].charAt(c) == player &&
                board[1].charAt(c) == player &&
                board[2].charAt(c) == player) {
                return true;
            }
        }

        // 대각선
        if (board[0].charAt(0) == player &&
            board[1].charAt(1) == player &&
            board[2].charAt(2) == player) {
            return true;
        }

        if (board[0].charAt(2) == player &&
            board[1].charAt(1) == player &&
            board[2].charAt(0) == player) {
            return true;
        }

        return false;
    }
}
