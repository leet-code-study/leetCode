class MyCalendar {

   private List<int[]> bookings;

    public MyCalendar() {
        bookings = new ArrayList<>();
    }

    public boolean book(int start, int end) {

        for (int[] b : bookings) {
            int s = b[0];
            int e = b[1];

            if (start < e && end > s) {
                return false;
            }
        }

        bookings.add(new int[]{start, end});
        return true;
    }
}

